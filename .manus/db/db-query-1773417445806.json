{
  "query": "\n-- Show blastPlayers with their current IDs\nSELECT id, fullName, blastEmail FROM blastPlayers ORDER BY fullName;\n\n-- Show blastSessions and whether their playerId matches any blastPlayer\nSELECT s.id as sessionId, s.playerId, s.sessionDate,\n  CASE WHEN p.id IS NULL THEN 'ORPHANED' ELSE 'OK' END as status\nFROM blastSessions s\nLEFT JOIN blastPlayers p ON s.playerId = p.id\nORDER BY status DESC, s.sessionDate DESC\nLIMIT 30;\n\n-- Count orphaned sessions\nSELECT \n  COUNT(*) as total_sessions,\n  SUM(CASE WHEN p.id IS NULL THEN 1 ELSE 0 END) as orphaned_sessions\nFROM blastSessions s\nLEFT JOIN blastPlayers p ON s.playerId = p.id;\n",
  "command": "mysql --batch --raw --column-names --default-character-set=utf8mb4 --host gateway02.us-east-1.prod.aws.tidbcloud.com --port 4000 --user 3knp7kHgPS8ePkR.root --database 4gdCHRuKFjrDK3bmH43Eh2 --execute \n-- Show blastPlayers with their current IDs\nSELECT id, fullName, blastEmail FROM blastPlayers ORDER BY fullName;\n\n-- Show blastSessions and whether their playerId matches any blastPlayer\nSELECT s.id as sessionId, s.playerId, s.sessionDate,\n  CASE WHEN p.id IS NULL THEN 'ORPHANED' ELSE 'OK' END as status\nFROM blastSessions s\nLEFT JOIN blastPlayers p ON s.playerId = p.id\nORDER BY status DESC, s.sessionDate DESC\nLIMIT 30;\n\n-- Count orphaned sessions\nSELECT \n  COUNT(*) as total_sessions,\n  SUM(CASE WHEN p.id IS NULL THEN 1 ELSE 0 END) as orphaned_sessions\nFROM blastSessions s\nLEFT JOIN blastPlayers p ON s.playerId = p.id;\n",
